---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  entry: CollectionEntry<'blog'>;
}
---

<BaseLayout
  seo={{
    title: Astro.props.entry.data.title,
    description: Astro.props.entry.data.description,
    type: 'article',
    publishedTime: Astro.props.entry.data.pubDate.toISOString(),
    tags: Astro.props.entry.data.tags,
    canonical: `/blog/${Astro.props.entry.id.replace(/\.(md|mdx)$/, '')}/`,
  }}
>
  <article class="container-main py-24">
    <div class="mx-auto max-w-3xl">
      <header class="mb-10">
        <p class="mb-2 text-sm font-semibold text-emerald-400">
          {Astro.props.entry.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
        <h1 class="text-3xl font-bold text-slate-100 sm:text-4xl">{Astro.props.entry.data.title}</h1>
        <p class="mt-4 text-lg text-slate-400">{Astro.props.entry.data.description}</p>
        {Astro.props.entry.data.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {Astro.props.entry.data.tags.map(tag => (
              <span class="rounded-full bg-slate-800 px-3 py-1 text-xs font-medium text-slate-300">{tag}</span>
            ))}
          </div>
        )}
      </header>
      <div class="prose prose-invert-custom max-w-none">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>