---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO, { type Props as SEOProps } from '../components/SEO.astro';

export type { Props as SEOProps } from '../components/SEO.astro';

export interface Props {
  seo?: SEOProps;
}

const { seo } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0F172A" />
    <SEO {...seo} />
  </head>
  <body>
    <Header />
    <main class="min-h-screen">
      <slot />
    </main>
    <Footer />

    <!-- WebMCP: Expose site tools to AI agents via the browser -->
    <!-- https://webmachinelearning.github.io/webmcp/ -->
    <script>
      (() => {
        if (typeof navigator.modelContext?.provideContext !== 'function') return;

        navigator.modelContext.provideContext([
          {
            name: 'navigate_to_docs',
            description: 'Navigate to the ZDR Chat documentation page',
            inputSchema: {
              type: 'object',
              properties: {
                section: {
                  type: 'string',
                  description: 'Optional documentation section slug (e.g., getting-started, features, faq)',
                },
              },
            },
            execute: async ({ section }) => {
              const path = section ? `/docs/${section}/` : '/docs/';
              window.location.href = path;
              return { success: true, path };
            },
          },
          {
            name: 'navigate_to_blog',
            description: 'Navigate to the ZDR Chat blog page',
            inputSchema: {
              type: 'object',
              properties: {},
            },
            execute: async () => {
              window.location.href = '/blog/';
              return { success: true };
            },
          },
          {
            name: 'navigate_to_privacy',
            description: 'Navigate to the ZDR Chat privacy policy page',
            inputSchema: {
              type: 'object',
              properties: {},
            },
            execute: async () => {
              window.location.href = '/privacy/';
              return { success: true };
            },
          },
          {
            name: 'launch_app',
            description: 'Launch the ZDR Chat application (opens app.zdr.chat in new tab)',
            inputSchema: {
              type: 'object',
              properties: {},
            },
            execute: async () => {
              window.open('https://app.zdr.chat', '_blank');
              return { success: true };
            },
          },
        ]);
      })();
    </script>
  </body>
</html>