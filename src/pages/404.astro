---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
---

<BaseLayout seo={{
  title: 'Page Not Found',
}}>
  <div class="container-main flex min-h-[70vh] flex-col items-center justify-center text-center">
    <span class="text-8xl font-bold text-slate-700">404</span>
    <h1 class="mt-4 text-2xl font-bold text-slate-100">Page not found</h1>
    <p class="mt-2 text-slate-400">This page doesn't exist or has been moved.</p>
    <div class="mt-8 flex gap-4">
      <CTAButton href="/">Go Home</CTAButton>
      <CTAButton href="/docs/" variant="secondary">Browse Docs</CTAButton>
    </div>
  </div>
</BaseLayout>