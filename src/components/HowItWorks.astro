---
const steps = [
  {
    step: 1,
    icon: '🔑',
    title: 'Paste your OpenRouter key',
    description: 'Get your API key from OpenRouter and paste it into the app. It stays in your browser — always.',
  },
  {
    step: 2,
    icon: '🎯',
    title: 'Pick a model',
    description: 'Browse 300+ models by category — smartest, fastest, free, code, vision. Neatly bucketed so you always pick the right one.',
  },
  {
    step: 3,
    icon: '💬',
    title: 'Start chatting',
    description: 'Every message stays in your browser. The status bar tracks tokens and cost in real time. No subscription — you pay OpenRouter directly.',
  },
];
---

<section class="py-20">
  <div class="container-main">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="section-heading">How It Works</h2>
      <p class="section-subheading">Three simple steps to start chatting privately.</p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-3">
      {steps.map(({ step, icon, title, description }) => (
        <div class="relative text-center">
          <!-- Connector line -->
          {step < 3 && (
            <div class="absolute top-8 left-[60%] hidden h-px w-[80%] border-t border-dashed border-slate-700 md:block" aria-hidden="true" />
          )}
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-emerald-500/10 text-3xl">
            {icon}
          </div>
          <div class="mt-2 mb-2 text-xs font-semibold tracking-widest text-emerald-400 uppercase">Step {step}</div>
          <h3 class="text-lg font-semibold text-slate-100">{title}</h3>
          <p class="mt-2 text-sm text-slate-400">{description}</p>
        </div>
      ))}
    </div>
  </div>
</section>