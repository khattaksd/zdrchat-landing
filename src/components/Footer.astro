---
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-800 bg-slate-950">
  <div class="container-main py-12">
    <div class="grid gap-8 md:grid-cols-4">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 text-lg font-bold text-slate-100">
          <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-emerald-500/10 text-emerald-400 font-bold text-sm">Z</span>
          ZDR Chat
        </a>
        <p class="mt-3 max-w-xs text-sm text-slate-400">
          Private, serverless AI chat. Bring your own key, zero data retention.
          Your conversations stay in your browser — always.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="mb-3 text-sm font-semibold text-slate-200">Site</h3>
        <ul class="space-y-2 text-sm text-slate-400">
          <li><a href="/blog/" class="hover:text-emerald-400 transition-colors">Blog</a></li>
          <li><a href="/docs/" class="hover:text-emerald-400 transition-colors">Docs</a></li>
          <li><a href="/privacy/" class="hover:text-emerald-400 transition-colors">Privacy</a></li>
        </ul>
      </div>

      <!-- External -->
      <div>
        <h3 class="mb-3 text-sm font-semibold text-slate-200">Links</h3>
        <ul class="space-y-2 text-sm text-slate-400">
          <li><a href="https://app.zdr.chat" class="hover:text-emerald-400 transition-colors">Launch App</a></li>
          <li><a href="https://github.com/khattaksd/zdrchat" class="hover:text-emerald-400 transition-colors">GitHub</a></li>
          <li><a href="https://openrouter.ai/keys" class="hover:text-emerald-400 transition-colors">OpenRouter Keys</a></li>
          <li><a href="https://openrouter.ai/settings/privacy" class="hover:text-emerald-400 transition-colors">OpenRouter Privacy Settings</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 border-t border-slate-800 pt-6 text-center text-xs text-slate-500">
      <p>&copy; {year} ZDR Chat. Made for the privacy-conscious. Not affiliated with OpenRouter.</p>
    </div>
  </div>
</footer>