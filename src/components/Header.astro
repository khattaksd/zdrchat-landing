---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/blog/', label: 'Blog' },
  { href: '/docs/', label: 'Docs' },
  { href: '/privacy/', label: 'Privacy' },
];
---

<header class="fixed top-0 right-0 left-0 z-50 border-b border-slate-800/80 bg-slate-900/80 backdrop-blur-md">
  <nav class="container-main flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-xl font-bold text-slate-100 hover:text-emerald-400 transition-colors">
      <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-500/10 text-emerald-400 font-bold">Z</span>
      ZDR Chat
    </a>

    <div class="hidden items-center gap-1 sm:flex">
      {navItems.map(item => (
        <a
          href={item.href}
          class="rounded-lg px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800 hover:text-slate-100"
        >
          {item.label}
        </a>
      ))}
    </div>

    <a
      href="https://app.zdr.chat"
      class="btn-primary text-sm"
    >
      Launch App
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
      </svg>
    </a>
  </nav>
</header>